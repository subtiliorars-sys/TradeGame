{
  "name": "tradegame-sim",
  "version": "0.1.0",
  "private": true,
  "description": "TradeGame deterministic sim engine — Phase 2 foundation. Render-agnostic; Phaser arrives with the UI layer.",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.ui.config.ts",
    "build": "tsc --noEmit && vite build",
    "build:ui": "tsc --noEmit --project tsconfig.ui.json && vite build --config vite.ui.config.ts",
    "typecheck:ui": "tsc --noEmit --project tsconfig.ui.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint-pnl": "node scripts/lint-pnl.mjs",
    "verify": "node scripts/verify.mjs"
  },
  "dependencies": {
    "phaser": "^3.85.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "~5.5.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
