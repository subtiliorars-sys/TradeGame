{
  // UI-layer tsconfig — extends the engine base but adds DOM lib for Phaser.
  // The engine tsconfig (tsconfig.json) intentionally excludes DOM so the
  // render-agnostic engine core is never accidentally coupled to browser APIs.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "rootDir": ".",
    "outDir": "dist-ui"
  },
  // Override the INHERITED exclude — the base excludes src/ui/** (engine
  // purity), which silently propagated here and left the entire UI layer
  // untypechecked (caught when a deliberately wrong field compiled clean).
  "exclude": ["node_modules", "dist", "dist-ui", "tests"],
  "include": ["src/**/*.ts"]
}
